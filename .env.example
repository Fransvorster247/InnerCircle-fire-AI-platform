# Application
APP_NAME=InnerCircle Fire Platform
APP_ENV=development
DEBUG=True

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/innercircle_fire
DATABASE_ECHO=True

# OpenAI API
OPENAI_API_KEY=sk-xxx
OPENAI_MODEL=gpt-4o
EMBEDDING_MODEL=text-embedding-3-large

# Vector Database (Pinecone)
PINCONE_API_KEY=xxx
PINCONE_ENVIRONMENT=production
PINCONE_INDEX_NAME=innercircle-fire-standards

# JWT & Security
SECRET_KEY=your-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS
CORS_ORIGINS=["http://localhost:3000","http://localhost:8000"]

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/app.log

# AWS S3 (for file uploads)
AWS_ACCESS_KEY_ID=xxx
AWS_SECRET_ACCESS_KEY=xxx
AWS_S3_BUCKET=innercircle-fire-uploads
AWS_REGION=eu-west-1

# External APIs
SLACK_WEBHOOK_URL=https://hooks.slack.com/...
IOT_GATEWAY_URL=http://localhost:8080
IOT_GATEWAY_KEY=xxx

# Email (for notifications)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# Stripe (future billing)
STRIPE_API_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
